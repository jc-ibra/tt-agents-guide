# Este subdirectorio es un sitio estático (manual GLPI).
# GLPI, en la raíz del dominio, reescribe todo hacia su router.
# Apagamos esa reescritura heredada SOLO para esta carpeta.
<IfModule mod_rewrite.c>
  RewriteEngine Off
</IfModule>

# Servir index.html al entrar a una carpeta.
DirectoryIndex index.html index.htm

# No exponer el repositorio git ni los archivos internos.
<FilesMatch "^(CLAUDE\.md|CAPTURAS\.md)$">
  Require all denied
</FilesMatch>
RedirectMatch 404 /\.git

# Tipos MIME correctos por si el server no los define.
<IfModule mod_mime.c>
  AddType text/markdown .md
  AddType application/json .json
  AddType text/javascript .js
</IfModule>
