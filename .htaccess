# La raíz del subdominio sirve el PORTAL de perfiles (index.html).
# Cada perfil vive en /perfiles/<perfil>/ y comparte el motor en /engine/.
DirectoryIndex index.html index.htm

<IfModule mod_rewrite.c>
  RewriteEngine On
</IfModule>

# No exponer los archivos internos del repositorio.
RedirectMatch 404 /\.git
<FilesMatch "^(CLAUDE\.md|CAPTURAS\.md|NOTAS-INTERNAS-REVISAR\.md)$">
  Require all denied
</FilesMatch>

# Tipos MIME correctos por si el server no los define.
<IfModule mod_mime.c>
  AddType text/markdown .md
  AddType application/json .json
  AddType text/javascript .js
</IfModule>
