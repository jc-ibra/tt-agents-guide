# El sitio (manual GLPI) vive dentro de /web/.
# Al entrar a la raíz del subdominio, redirige a /web/.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^$ /web/ [R=301,L]
</IfModule>

DirectoryIndex index.html index.htm

# No exponer el repositorio git ni los archivos internos.
RedirectMatch 404 /\.git
<FilesMatch "^(CLAUDE\.md|CAPTURAS\.md|NOTAS-INTERNAS-REVISAR\.md)$">
  Require all denied
</FilesMatch>

# Tipos MIME correctos por si el server no los define.
<IfModule mod_mime.c>
  AddType text/markdown .md
  AddType application/json .json
  AddType text/javascript .js
</IfModule>
